{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/catalog/*": [
        "./src/modules/catalog/*"
      ],
      "@/profile/*": [
        "./src/modules/profile/*"
      ],
      "@/recommendation/*": [
        "./src/modules/recommendation/*"
      ],
      "@/content/*": [
        "./src/modules/content/*"
      ],
      "@/partner/*": [
        "./src/modules/partner/*"
      ],
      "@/ops/*": [
        "./src/modules/ops/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/db/seed*.ts",
    "scripts"
  ]
}
